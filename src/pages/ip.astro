---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout sideBarActiveItemID="ip" title="Visitor Analytics" description="Website visitor tracking and analytics">
  <div class="pb-12 mt-5">
    <div class="text-4xl font-bold mb-2">Visitor Analytics</div>
    <div class="text-sm opacity-50 mb-6">Who visited my website</div>

    <!-- Overview Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="stat bg-base-200 rounded-lg shadow">
        <div class="stat-title">Total Visits</div>
        <div class="stat-value" id="s-total">-</div>
      </div>
      <div class="stat bg-base-200 rounded-lg shadow">
        <div class="stat-title">Unique Visitors</div>
        <div class="stat-value" id="s-unique">-</div>
      </div>
      <div class="stat bg-base-200 rounded-lg shadow">
        <div class="stat-title">Countries</div>
        <div class="stat-value" id="s-countries">-</div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="card bg-base-200 shadow">
        <div class="card-body">
          <h2 class="card-title text-lg">Last 30 Days</h2>
          <canvas id="visits-chart" height="220"></canvas>
        </div>
      </div>
      <div class="card bg-base-200 shadow">
        <div class="card-body">
          <h2 class="card-title text-lg">Country Distribution</h2>
          <canvas id="country-chart" height="220"></canvas>
        </div>
      </div>
    </div>

    <!-- Page Views -->
    <div class="card bg-base-200 shadow mb-8">
      <div class="card-body">
        <h2 class="card-title text-lg">Top Pages</h2>
        <div id="pages-list" class="overflow-x-auto">
          <div class="flex items-center gap-2 py-4 justify-center opacity-50">
            <span class="loading loading-spinner loading-sm"></span> Loading...
          </div>
        </div>
      </div>
    </div>

    <!-- Visitors Table -->
    <div class="card bg-base-200 shadow">
      <div class="card-body">
        <h2 class="card-title text-lg mb-2">All Visitors</h2>
        <div class="overflow-x-auto">
          <table class="table table-zebra table-sm w-full">
            <thead>
              <tr>
                <th>#</th>
                <th>IP</th>
                <th>Location</th>
                <th>ISP</th>
                <th>Last Page</th>
                <th>Last Visit</th>
                <th>Visits</th>
              </tr>
            </thead>
            <tbody id="visitors-tbody">
              <tr>
                <td colspan="7" class="text-center py-4">
                  <span class="loading loading-spinner loading-sm"></span> Loading...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

  <script is:inline>
  (function() {
    var db = firebase.database();

    function flag(cc) {
      if (!cc) return "";
      return String.fromCodePoint(...cc.toUpperCase().split("").map(function(c){ return 0x1F1E6 + c.charCodeAt(0) - 65; }));
    }

    function relativeTime(ts) {
      var diff = Date.now() - ts;
      var m = Math.floor(diff / 60000);
      if (m < 1) return "just now";
      if (m < 60) return m + "m ago";
      var h = Math.floor(m / 60);
      if (h < 24) return h + "h ago";
      var d = Math.floor(h / 24);
      if (d < 30) return d + "d ago";
      return new Date(ts).toLocaleDateString();
    }

    Promise.all([
      db.ref("visitors").orderByChild("lastVisit").once("value"),
      db.ref("visits").orderByChild("timestamp").once("value")
    ]).then(function(results) {
      var visitorsSnap = results[0];
      var visitsSnap = results[1];

      // Parse visitors
      var visitors = [];
      visitorsSnap.forEach(function(c) { visitors.push(c.val()); });
      visitors.sort(function(a, b) { return (b.lastVisit || 0) - (a.lastVisit || 0); });

      // Parse visits timeline
      var visits = [];
      visitsSnap.forEach(function(c) { visits.push(c.val()); });

      // Overview
      var totalVisits = visits.length;
      var uniqueVisitors = visitors.length;
      var countries = {};
      visitors.forEach(function(v) { countries[v.country || "Unknown"] = true; });

      document.getElementById("s-total").textContent = totalVisits;
      document.getElementById("s-unique").textContent = uniqueVisitors;
      document.getElementById("s-countries").textContent = Object.keys(countries).length;

      // Visitors table
      var tbody = document.getElementById("visitors-tbody");
      if (visitors.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="text-center opacity-50">No visitors yet</td></tr>';
      } else {
        tbody.innerHTML = visitors.map(function(v, i) {
          var loc = (v.city ? v.city + ", " : "") + (v.country || "Unknown");
          return '<tr>' +
            '<td>' + (i + 1) + '</td>' +
            '<td><code class="text-xs">' + (v.ip || "-") + '</code></td>' +
            '<td>' + flag(v.countryCode) + ' ' + loc + '</td>' +
            '<td class="text-xs">' + (v.isp || "-") + '</td>' +
            '<td class="text-xs"><code>' + (v.lastPage || "/") + '</code></td>' +
            '<td class="text-xs">' + relativeTime(v.lastVisit) + '</td>' +
            '<td><span class="badge badge-sm badge-primary">' + (v.visitCount || 1) + '</span></td>' +
            '</tr>';
        }).join("");
      }

      // Top pages
      var pageCounts = {};
      visits.forEach(function(v) {
        var p = v.page || "/";
        pageCounts[p] = (pageCounts[p] || 0) + 1;
      });
      var sortedPages = Object.entries(pageCounts).sort(function(a, b) { return b[1] - a[1]; });
      var maxPageCount = sortedPages.length > 0 ? sortedPages[0][1] : 1;
      var pagesHtml = '<table class="table table-sm w-full">';
      sortedPages.forEach(function(entry) {
        var pct = Math.round(entry[1] / maxPageCount * 100);
        pagesHtml += '<tr><td class="w-40"><code class="text-xs">' + entry[0] + '</code></td>' +
          '<td><div class="flex items-center gap-2"><progress class="progress progress-primary w-full" value="' + pct + '" max="100"></progress>' +
          '<span class="text-xs font-mono w-8 text-right">' + entry[1] + '</span></div></td></tr>';
      });
      pagesHtml += '</table>';
      document.getElementById("pages-list").innerHTML = sortedPages.length > 0 ? pagesHtml : '<div class="text-center opacity-50 py-2">No data</div>';

      // Visits chart (last 30 days)
      var now = Date.now();
      var dailyCounts = {};
      for (var i = 0; i < 30; i++) {
        var d = new Date(now - (29 - i) * 86400000);
        dailyCounts[d.toISOString().split("T")[0]] = 0;
      }
      var thirtyDaysAgo = now - 30 * 86400000;
      visits.filter(function(v) { return v.timestamp >= thirtyDaysAgo; }).forEach(function(v) {
        var key = new Date(v.timestamp).toISOString().split("T")[0];
        if (dailyCounts[key] !== undefined) dailyCounts[key]++;
      });

      new Chart(document.getElementById("visits-chart"), {
        type: "bar",
        data: {
          labels: Object.keys(dailyCounts).map(function(d) { return d.slice(5); }),
          datasets: [{ label: "Visits", data: Object.values(dailyCounts), backgroundColor: "rgba(59,130,246,0.5)", borderColor: "rgba(59,130,246,1)", borderWidth: 1 }]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }, plugins: { legend: { display: false } } }
      });

      // Country chart
      var countryMap = {};
      visitors.forEach(function(v) {
        var c = v.country || "Unknown";
        countryMap[c] = (countryMap[c] || 0) + (v.visitCount || 1);
      });
      var sorted = Object.entries(countryMap).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 10);
      var colors = ["#3b82f6","#ef4444","#10b981","#f59e0b","#8b5cf6","#ec4899","#06b6d4","#84cc16","#f97316","#6366f1"];

      new Chart(document.getElementById("country-chart"), {
        type: "doughnut",
        data: {
          labels: sorted.map(function(e) { return e[0]; }),
          datasets: [{ data: sorted.map(function(e) { return e[1]; }), backgroundColor: colors.slice(0, sorted.length) }]
        },
        options: { responsive: true, plugins: { legend: { position: "right" } } }
      });
    }).catch(function(e) {
      console.error("Failed to load:", e);
      document.getElementById("visitors-tbody").innerHTML = '<tr><td colspan="7" class="text-center text-error">Failed to load data</td></tr>';
    });
  })();
  </script>
</BaseLayout>
